{
  "name": "mocha-play",
  "description": "Run mocha tests in chromium, using webpack and playwright.",
  "version": "9.0.0",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "types": "dist/index.d.ts",
  "bin": {
    "mocha-play": "bin/mocha-play.js"
  },
  "scripts": {
    "clean": "rimraf ./dist",
    "prebuild": "npm run clean",
    "build": "tsc --build",
    "pretest": "npm run build",
    "test": "npm run test:only",
    "test:only": "mocha \"./dist/test/**/*.spec.js\"",
    "prettify": "prettier . --write",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "mocha": ">=7 || >=12.0.0-beta",
    "webpack": "^5.0.0"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "create-listening-server": "^2.1.0",
    "express": "^5.2.1",
    "find-up": "^8.0.0",
    "glob": "^13.0.6",
    "html-webpack-plugin": "^5.6.7",
    "playwright-core": "^1.61.1",
    "webpack-dev-middleware": "^8.0.3"
  },
  "devDependencies": {
    "@playwright/browser-chromium": "^1.61.1",
    "@ts-tools/webpack-loader": "^7.0.0",
    "@types/chai": "^5.2.3",
    "@types/express": "^5.0.6",
    "@types/mocha": "^10.0.10",
    "@types/node": "22",
    "chai": "^6.2.2",
    "mocha": "^12.0.0-rc.2",
    "prettier": "^3.9.6",
    "rimraf": "^6.1.3",
    "typescript": "~6.0.3",
    "webpack": "^5.108.4"
  },
  "allowScripts": {
    "@playwright/browser-chromium": true
  },
  "files": [
    "bin",
    "static",
    "dist",
    "!dist/test",
    "src",
    "!*/tsconfig.{json,tsbuildinfo}"
  ],
  "prettier": {
    "printWidth": 120,
    "singleQuote": true
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dazl-dev/mocha-play.git"
  }
}
